:80 {
    # Enable modern, high-performance compression
    encode zstd gzip

    # API requests → backend
    handle /api/* {
        reverse_proxy backend:8001
    }

    # Everything else → React static files
    handle {
        # Set the root directory where the React build files live
        root * /srv
        # React client-side routing: try the file, then fallback to index.html
        try_files {path} /index.html
        # Enable the static file server
        file_server
    }

    # Setup aggressive caching for static assets (js, css, images, fonts)
    @static {
        file
        path *.ico *.css *.js *.gif *.webp *.avif *.jpg *.jpeg *.png *.svg *.woff *.woff2
    }

    header @static Cache-Control "max-age=31536000, public, immutable"

    # Basic security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer-when-downgrade
    }
}